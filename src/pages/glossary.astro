  @media (max-width: 480px) {
    .glossary-search-count { display: none; }
    .glossary-card-row {
      flex-direction: column;
      gap: 0.15em;
    }
    .glossary-card-row dt { min-width: 0; }
  }
</style>

<script is:inline define:vars={{ terms: termsForClient }}>
  (function () {
    const input = document.querySelector('[data-glossary-search]');
    const clearBtn = document.querySelector('[data-glossary-clear]');
    const countEl = document.querySelector('[data-glossary-count]');
    const emptyEl = document.querySelector('[data-glossary-empty]');
    const grid = document.querySelector('[data-glossary-grid]');
    if (!input || !grid) return;

    // 查 DOM 拿到 card 元素,与数据数组按 data-acronym 对齐
    const cards = Array.from(grid.querySelectorAll('[data-glossary-card]'));
    const total = cards.length;

    function setCount(visible) {
      if (countEl) countEl.textContent = '显示 ' + visible + ' / ' + total + ' 个';
    }

    function filter(q) {
      const needle = (q || '').trim().toLowerCase();
      let visible = 0;
      cards.forEach((card) => {
        const acronym = (card.getAttribute('data-acronym') || '').toLowerCase();
        if (!needle) {
          card.hidden = false;
          visible++;
          return;
        }
        // 先按 acronym 精确/前缀,再按 haystack 包含
        const term = terms.find((t) => t.id === card.id.replace(/^term-/, ''));
        const haystack = term ? term.haystack : acronym;
        const match = acronym.includes(needle) || haystack.includes(needle);
        card.hidden = !match;
        if (match) visible++;
      });
      setCount(visible);
      if (emptyEl) emptyEl.hidden = visible !== 0;
      if (clearBtn) clearBtn.hidden = !needle;
    }

    // 输入过滤(简单 debounce 避免快速输入卡顿)
    let timer = null;
    input.addEventListener('input', () => {
      if (timer) window.clearTimeout(timer);
      timer = window.setTimeout(() => filter(input.value), 60);
    });

    // 清除按钮
    if (clearBtn) {
      clearBtn.addEventListener('click', () => {
        input.value = '';
        filter('');
        input.focus();
      });
    }

    // 空状态里的快捷标签
    document.querySelectorAll('[data-glossary-tag]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const tag = btn.getAttribute('data-glossary-tag') || '';
        input.value = tag;
        filter(tag);
        input.focus();
      });
    });

    // Esc 清空
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && input.value) {
        input.value = '';
        filter('');
      }
    });

    // 初始
    setCount(total);
  })();
</script>
