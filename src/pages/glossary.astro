  body[data-mode='beginner'] .glossary-card-row dt {
    min-width: 7.5em;
  }
  body[data-mode='beginner'] .glossary-hero h1 {
    font-size: clamp(2rem, 4vw, 2.6rem);
  }
  body[data-mode='beginner'] .glossary-sub {
    font-size: 1.15rem;
  }
  body[data-mode='beginner'] .glossary-search {
    padding: 0.7rem 1rem 0.7rem 2.6rem;
  }
  body[data-mode='beginner'] .glossary-search-input {
