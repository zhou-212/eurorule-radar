  /* 老手模式:白底,字号紧凑,信息密度高 */
  body[data-mode='expert'] .glossary-card {
    background: #fff;
    padding: 1rem 1.1rem 0.95rem 1.1rem;
  }
  body[data-mode='expert'] .glossary-card-oneliner {
