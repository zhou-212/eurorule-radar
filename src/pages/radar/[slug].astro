  }
  body[data-mode='beginner'] .quick-jump-list a:hover {
    color: #b45309;
  }

  /* ---------- prose 主体(模式差异) ---------- */
  .detail-prose {
    line-height: 1.75;
  }
  /* H2 emoji 前缀由 SSR <style is:inline> ::before 注入(见 <style is:inline>)
     这里只给 emoji 字符加间距 / 字号微调(覆盖 inline style 默认) */
  .detail-prose h2::before {
    display: inline-block;
    margin-right: 0.4em;
    font-size: 1.05em;
