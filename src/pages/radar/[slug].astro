---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getRiskClass, getStatusClass, getContentKindClass, SITE_DEFAULTS } from '../../lib/radar';
import { formatDate, daysFromNow } from '../../lib/date';
import RadarCard from '../../components/RadarCard.astro';
import { withBase, siteAsDir } from '../../lib/url';

export async function getStaticPaths() {
  const all = await getCollection('radar', ({ data }) => !data.draft);
  return all.map((entry) => ({
    params: { slug: entry.id.replace(/\.(md|mdx)$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

/**
 * 提取 markdown 原文的第一段(简介):
 *  - 跳过空行
 *  - 遇到标题(## / ### ...)即停止
 *  - 同段内的多行用空格连接
 *  - 限制 200 字,过长加省略号
 */
function firstParagraph(md: string): string {
  if (!md) return '';
  const lines = md.split(/\r?\n/);
  const buf: string[] = [];
  for (const line of lines) {
    const trimmed = line.trim();
    if (!trimmed) {
      if (buf.length > 0) break;
      continue;
    }
    if (/^#{1,6}\s/.test(trimmed)) break;
    buf.push(trimmed);
  }
  const text = buf.join(' ');
  if (text.length <= 200) return text;
  return text.slice(0, 200) + '…';
}
const firstPara = firstParagraph(entry.body || '');

/**
 * 倒计时徽标(SSR 算好,避免 hydration mismatch):
 *   - 触发前提:contentKind === '近期更新' && 有 deadlineDate
 *   - days = daysFromNow(deadlineDate)
 *   - days <= 0 (已逾期) && status !== '生效中' → 🚨 已逾期 X 天
 *     (status='生效中' 表示规则已自然进入"生效"状态,不再视为待办 → 不展示)
 *   - 0 < days <= 30 → 🔥 距生效 X 天
 *   - 其余情况 → null(不展示)
 */
type DeadlineBadge = { kind: 'overdue' | 'urgent'; days: number; text: string };
const deadlineBadge: DeadlineBadge | null = (() => {
  if (d.contentKind !== '近期更新' || !d.deadlineDate) return null;
  const days = daysFromNow(d.deadlineDate);
  if (days <= 0) {
    if (d.status === '生效中') return null;
    return { kind: 'overdue', days: -days, text: `🚨 已逾期 ${-days} 天` };
  }
  if (days <= 30) {
    return { kind: 'urgent', days, text: `🔥 距生效 ${days} 天` };
  }
  return null;
})();

// 截止日期是否紧(<=30 天)用于 expert 模式红底白字
const deadlineUrgent: boolean =
  !!d.deadlineDate && (() => {
    const days = daysFromNow(d.deadlineDate);
    return days > 0 && days <= 30;
  })();

/**
 * 解析 markdown 的 H2 列表(SSR 阶段)
 *   - 用于生成"老手模式快速跳转"导航
 *   - 同步给 client script 用,知道哪些 H2 要在新手模式 wrap 进 <details>
 *   - id 走 Astro 默认的 slug 规则(中文字符保留;Astro 直接把原文塞进 id)
 *
 * 返回: { text: string; id: string; fold: boolean }[]
 *   fold: true 表示该 H2 段在新手模式要折叠(对应"关键时间线 / 核心义务 /
 *        你现在要做什么 / 不处理的潜在影响 / 常见问题 / 官方 / 亚马逊相关
 *        动作 / 亚马逊 DoC / 相关规则 / 相关清单 / 核对日期 / 免责声明")
 */
function extractH2List(md: string): { text: string; id: string; fold: boolean }[] {
  if (!md) return [];
  const FOLD_KEYWORDS = [
    '核心义务', '关键时间线', '你现在要做什么', '不处理的潜在影响',
    '常见问题', '常见误区', '官方', '亚马逊相关动作', '亚马逊',
    '相关规则', '相关清单', '核对日期', '风险提示与免责声明',
    '合规清单', '5 维对比表', '三国对比表', '新卖家',
    '包装最小化', '物质限制', '标签与溯源', '可回收',
    '数字电池护照', '碳足迹', '回收效率',
  ];
  const out: { text: string; id: string; fold: boolean }[] = [];
  const lines = md.split(/\r?\n/);
  for (const line of lines) {
    const m = /^##\s+(.+?)\s*$/.exec(line);
    if (!m) continue;
    const text = m[1].trim();
    const id = text; // Astro 渲染出的 id 就是原文
    const fold = FOLD_KEYWORDS.some((kw) => text.includes(kw));
    out.push({ text, id, fold });
  }
  return out;
}
const h2List = extractH2List(entry.body || '');
// 给 client script 用的纯文本 fold key 列表(序列化进 data-attr)
const foldKeys = h2List.filter((h) => h.fold).map((h) => h.text);

/**
 * H2 emoji 关键词映射(SSR 端,用于 inline <style> ::before 注入)
 * 关键词顺序敏感 — 更具体的放前面
 * 同步的客户端版本在 <script> 块 pickEmoji() (用于 fold summary)
 */
function pickEmoji(text: string): string {
  if (text.includes('一句话结论')) return '🎯';
  if (text.includes('这是啥')) return '📖';
  if (text.includes('为什么跟你有关')) return '🤝';
  if (text.includes('适用范围')) return '🎯';
  if (text.includes('关键时间线') || text.includes('关键时间')) return '⏰';
  if (text.includes('核心义务') || text.includes('核心变化')) return '⚙️';
  if (text.includes('你现在要做什么') || text.includes('你要做什么')) return '✅';
  if (text.includes('不处理') || text.includes('不做的')) return '⚠️';
  if (text.includes('常见误区')) return '💡';
  if (text.includes('常见问题')) return '❓';
  if (text.includes('风险提示')) return '⚠️';
  if (text.includes('合规清单')) return '☑️';
  if (text.includes('核对日期')) return '📅';
  if (text.includes('相关规则')) return '🔀';
  if (text.includes('相关清单')) return '📋';
  if (text.includes('官方') || text.includes('原始来源') || text.includes('来源')) return '🔗';
  if (text.includes('亚马逊')) return '🛒';
  return '📌';
}

// 始终展开的关键 H2 列表(用于 quick-jump 排除) — 一句话结论 / 适用范围
// 在新手 / 老手都展开,不放进 fold
const quickJumpH2s = h2List.filter(
  (h) => !h.text.includes('一句话结论'),
);

// 相关规则:同 categories 交集
const allRadars = (await getCollection('radar', ({ data }) => !data.draft))
  .filter((r) => r.id !== entry.id);
const related = allRadars
  .filter((r) => r.data.categories.some((c) => d.categories.includes(c)))
  .slice(0, 3);

const siteStr = siteAsDir(Astro.site);
const slug = entry.id.replace(/\.(md|mdx)$/, '');

/**
 * 新手提示区(SSR 算好,无 hydration):
 *   - schema 没加 beginnerHint 字段,走 fallback 模板
 *   - 用 categories[0] 推"产品类目",countries 推"销售国家"
 *   - "做什么"用 summary 前 30 字(已是产品的合规要求概述)
 *   - "最高罚"若无 deadlineDate 不显示
 */
const beginnerHint = (() => {
  const productType = d.categories[0] || '在欧盟销售的商品';
  const region = d.countries.join(' / ');
  const summaryShort = d.summary.replace(/^[^:：]+[:：]\s*/, '').slice(0, 40);
  const action = summaryShort || '满足该法规的合规要求';
  const deadline = d.deadlineDate
    ? `,截止 ${formatDate(d.deadlineDate)}`
    : '';
  return {
    productType,
    region,
    action,
    deadline,
  };
})();

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '首页', item: siteStr || undefined },
    { '@type': 'ListItem', position: 2, name: '规则雷达', item: siteStr ? `${siteStr}radar/` : undefined },
    { '@type': 'ListItem', position: 3, name: d.title, item: siteStr ? `${siteStr}radar/${slug}/` : undefined },
  ],
};

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: d.title,
  description: d.summary,
  datePublished: d.publishedDate.toISOString(),
  dateModified: d.verifiedDate.toISOString(),
  inLanguage: 'zh-CN',
  author: { '@type': 'Organization', name: SITE_DEFAULTS.name },
  publisher: {
    '@type': 'Organization',
    name: SITE_DEFAULTS.name,
    logo: siteStr ? { '@type': 'ImageObject', url: `${siteStr}favicon.svg` } : undefined,
  },
  mainEntityOfPage: siteStr ? `${siteStr}radar/${slug}/` : undefined,
};
---

<BaseLayout
  title={d.title}
  description={d.summary}
  type="article"
  publishedDate={d.publishedDate}
  modifiedDate={d.verifiedDate}
  jsonLd={[breadcrumb, articleJsonLd]}
>
  <article class="container detail-page">
    <nav class="breadcrumb" aria-label="面包屑">
      <a href={withBase('/')}>首页</a>
      <span class="breadcrumb-sep">/</span>
      <a href={withBase('/radar/')}>规则雷达</a>
      <span class="breadcrumb-sep">/</span>
      <span>{d.title}</span>
    </nav>

    <!--
      模式提示横幅:
        - 大黄横幅(新手) / 深色横幅(老手)
        - 文案 / 颜色 / 圆角 / 字号都不同
        - 由 body[data-mode] 通过 mode-novice-only / mode-expert-only 控制显示
    -->
    <p class="mode-banner mode-banner-novice mode-novice-only" role="note">
      <span class="mode-banner-icon" aria-hidden="true">🌱</span>
      <span>
        新手模式:这一法规用大白话讲,重点看"<strong>你要做什么</strong>"那一段;
        不懂的字用<em>斜体</em>标了
      </span>
    </p>
    <p class="mode-banner mode-banner-expert mode-expert-only" role="note">
      <span class="mode-banner-icon" aria-hidden="true">⚡</span>
      <span>
        老手模式:看<strong>条款号</strong>、<strong>截止日期</strong>、<strong>原文链接</strong>。
        左侧目录可快速跳到任一节
      </span>
    </p>

    <header class="radar-detail-head">
      <div class="radar-detail-tags">
        <span class={`risk ${getRiskClass(d.riskLevel)}`}>风险:{d.riskLevel}</span>
        <span class={`status ${getStatusClass(d.status)}`}>{d.status}</span>
        <span class={`kind ${getContentKindClass(d.contentKind)}`}>内容状态:{d.contentKind}</span>
        {deadlineUrgent && (
          <span class="deadline-urgent-badge mode-expert-only" role="status" aria-label="截止日期紧迫">
            ⏰ 截止:{d.deadlineDate ? formatDate(d.deadlineDate) : ''}
          </span>
        )}
      </div>
      <div class="radar-detail-title-row">
        <h1>
          {d.title}
          {deadlineBadge && (
            <span
              class={`deadline-badge deadline-badge-${deadlineBadge.kind}`}
              role="status"
              aria-label={deadlineBadge.kind === 'overdue' ? `已逾期 ${deadlineBadge.days} 天` : `距生效 ${deadlineBadge.days} 天`}
            >
              {deadlineBadge.text}
            </span>
          )}
        </h1>
        <button
          type="button"
          class="btn btn-ghost btn-sm copy-summary-btn"
          data-copy-summary
          data-cs-title={d.title}
          data-cs-status={d.status}
          data-cs-risk={d.riskLevel}
          data-cs-effective={d.effectiveDate ? d.effectiveDate.toISOString().slice(0, 10) : ''}
          data-cs-slug={slug}
          data-cs-summary={firstPara}
          aria-label="复制 Markdown 摘要到剪贴板"
        >
          <span class="copy-default">📋 复制摘要</span>
        </button>
      </div>
      <p class="radar-detail-summary">{d.summary}</p>

      <!-- 一句话结论:新手模式放大高亮,老手模式普通字号
           - firstPara 是从 markdown body 解析的首段,首行是 ## 标题时为空
           - 用 firstPara 优先,空时回落到 d.summary(frontmatter 一句话简介) -->
      {(firstPara || d.summary) && (
        <div class="detail-elevator mode-novice-only" aria-label="一句话结论">
          <span class="detail-elevator-tag">🌱 一句话结论</span>
          <p class="detail-elevator-text">{firstPara || d.summary}</p>
        </div>
      )}

      <dl class="radar-detail-meta">
        <div><dt>内容状态</dt><dd>{d.contentKind}</dd></div>
        <div><dt>适用范围</dt><dd>{d.countries.join('、')}</dd></div>
        <div><dt>平台</dt><dd>{d.platform}</dd></div>
        <div><dt>核对日期</dt><dd><time datetime={d.verifiedDate.toISOString()}>{formatDate(d.verifiedDate)}</time></dd></div>
        {d.effectiveDate && <div><dt>生效日期</dt><dd><time datetime={d.effectiveDate.toISOString()}>{formatDate(d.effectiveDate)}</time></dd></div>}
        {d.deadlineDate && <div><dt>截止日期</dt><dd><time datetime={d.deadlineDate.toISOString()}>{formatDate(d.deadlineDate)}</time></dd></div>}
        <div><dt>来源</dt><dd><a href={d.sourceUrl} target="_blank" rel="noopener noreferrer">{d.sourceName}</a></dd></div>
      </dl>

      {d.contentKind === '基础规则' && (
        <p class="content-kind-note">
          <strong>这是基础规则 / 常驻要求</strong>。本站是基础规则 + 近期更新两类内容,本卡属于前者:
          长期有效的合规要求(如 GPSR 责任人、LUCID 注册等),不是"新近发布的变化"。
          如果你正在追踪 2026 年的新公告,目前<strong>暂未发布已核实的近期更新</strong>;
          请<strong>定期回访</strong>本站或关注项目 GitHub 仓库的更新。
        </p>
      )}
      {d.contentKind === '近期更新' && (
        <p class="content-kind-note kind-note-update">
          <strong>这是已核对的近期更新</strong>。有具体更新日期 / 修订内容 / 执法动态;
          建议优先处理,核对日期前的旧版可能已落后。
        </p>
      )}
      {d.contentKind === '示例' && (
        <p class="content-kind-note kind-note-example">
          <strong>这是示例 / 演示内容</strong>,用于展示"待核实"或编辑模板,
          <strong>不代表任何具体新规</strong>。具体执行请按你产品适用指令查原文。
        </p>
      )}
      {d.contentKind === '待核实' && (
        <p class="content-kind-note kind-note-pending">
          <strong>这条规则的来源尚未核实</strong>;请勿直接当作合规结论使用,等待运营补充官方原始来源。
        </p>
      )}
    </header>

    <!--
      老手模式"快速跳转"导航(只在 expert 模式显示)
      - 行内 anchor 链接,跳到各 H2
      - 由 SSR 阶段从 markdown 解析 H2 列表生成
    -->
    {quickJumpH2s.length > 0 && (
      <nav class="quick-jump mode-expert-only" aria-label="快速跳转">
        <span class="quick-jump-label">📑 快速跳转</span>
        <ol class="quick-jump-list">
          {quickJumpH2s.map((h) => (
            <li><a href={`#${h.id}`}>{h.text}</a></li>
          ))}
        </ol>
      </nav>
    )}

    {d.example && d.contentKind !== '示例' && (
      <div class="notice notice-warn">
        <strong>这是示例 / 演示内容</strong>,用于展示"待核实"内容的视觉标记和编辑模板,不代表任何具体新规。具体执行请按你产品适用指令查原文,或咨询专业律师 / 认证机构。
      </div>
    )}

    <!--
      H2 emoji 前缀(SSR 注入)
        - 用 ::before 伪元素为每个 H2 id 注入固定 emoji
        - 注入到 <style is:inline> → dist HTML 字面含 emoji 字符
        - 浏览器无 JS 也能看到
    -->
    <style is:inline set:html={
      h2List.map((h) =>
        `.detail-prose h2[id="${h.id}"]::before{content:"${pickEmoji(h.text)} ";}`
      ).join('\n')
    } />

    <!--
      prose 主体:
        - 把要 fold 的 H2 段名序列化进 data-fold-keys,给 client script 读
        - 切换模式时:beginner → wrap 进 <details>;expert → unwrap
    -->
    <div
      class="prose detail-prose"
      data-prose-fold
      data-fold-keys={JSON.stringify(foldKeys)}
    >
      <Content />
    </div>

    {related.length > 0 && (
      <section class="related">
        <h2>相关规则</h2>
        <div class="grid grid-3">
          {related.map((r) => <RadarCard entry={r} />)}
        </div>
      </section>
    )}

    <section class="related">
      <h2>相关清单</h2>
      <ul class="related-list">
        <li><a href={withBase('/checklists/new-seller-basics/')}>亚马逊欧洲站新卖家基础资料检查清单</a></li>
        <li><a href={withBase('/checklists/pre-listing-documents/')}>产品上架前资料检查清单</a></li>
        <li><a href={withBase('/checklists/compliance-notice-48h/')}>收到平台合规通知后的 48 小时应对清单</a></li>
      </ul>
    </section>

    <div class="notice notice-info related">
      <strong>操作建议:</strong>完成本规则的"你现在要做什么"清单后,到
      <a href={withBase('/checklists/compliance-notice-48h/')}>《48 小时应对清单》</a>
      登记你的执行进度,有助于团队协作和复盘。
    </div>

    <!--
      新手模式底部:新手提示 + "你还想知道什么?" 3 跳转
      - 整块在 mode-novice-only 下显示
      - SSR 阶段生成
    -->
    <aside class="beginner-footer mode-novice-only" data-beginner-hint>
      <div class="beginner-hint">
        <div class="beginner-hint-head">
          <span class="beginner-hint-emoji" aria-hidden="true">🌱</span>
          <h2 class="beginner-hint-title">新手还要知道</h2>
        </div>
        <p class="beginner-hint-text">
          这个法规要求 <strong>{beginnerHint.productType}</strong> 在
          <strong>{beginnerHint.region}</strong> 通过
          <strong>{beginnerHint.action}</strong> 才能卖
          {beginnerHint.deadline && <span>({beginnerHint.deadline.slice(1)})</span>}。
          不做的话亚马逊会下架你的 listing,严重时还要被罚钱。
        </p>
        <p class="beginner-hint-text beginner-hint-cta">
          想先弄懂几个词?去看
          <a href={withBase('/glossary/')}>名词解释</a> ·
          想确认这条规则跟你有没有关系?去做
          <a href={withBase('/self-check/')}>适不适合自检</a> ·
          头 30 天不知道从哪开始?看
          <a href={withBase('/checklists/first-30-days-survival/')}>新手救命清单</a>
        </p>
      </div>

      <div class="beginner-next">
        <h3 class="beginner-next-title">📚 你还想知道什么?</h3>
        <ul class="beginner-next-list">
          <li>
            <a href={withBase('/glossary/')}>
              <span class="beginner-next-emoji" aria-hidden="true">📖</span>
              <span class="beginner-next-text">
                <strong>名词解释</strong>
                <small>看不懂的法规术语,这里有人话版</small>
              </span>
            </a>
          </li>
          <li>
            <a href={withBase('/self-check/')}>
              <span class="beginner-next-emoji" aria-hidden="true">✅</span>
              <span class="beginner-next-text">
                <strong>适不适合自检</strong>
                <small>5 道题,看这条规则跟你有没有关系</small>
              </span>
            </a>
          </li>
          <li>
            <a href={withBase('/checklists/first-30-days-survival/')}>
              <span class="beginner-next-emoji" aria-hidden="true">🆘</span>
              <span class="beginner-next-text">
                <strong>头 30 天救命清单</strong>
                <small>刚开欧洲站,前 30 天必做 10 件事</small>
              </span>
            </a>
          </li>
        </ul>
      </div>
    </aside>

    <!--
      老手模式底部:参考链接紧凑表格 + 亚马逊相关动作快捷入口
      - mode-expert-only
    -->
    <aside class="expert-footer mode-expert-only">
      <h2 class="expert-footer-title">🔗 参考链接 / 跳转</h2>
      <table class="table expert-refs-table">
        <thead>
          <tr>
            <th>类别</th>
            <th>名称</th>
            <th>类型</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>法规原文</td>
            <td><a href={d.sourceUrl} target="_blank" rel="noopener noreferrer">{d.sourceName}</a></td>
            <td><code>外部</code></td>
          </tr>
          <tr>
            <td>核对日期</td>
            <td><time datetime={d.verifiedDate.toISOString()}>{formatDate(d.verifiedDate)}</time></td>
            <td><code>站点</code></td>
          </tr>
          {d.effectiveDate && (
            <tr>
              <td>生效日期</td>
              <td><time datetime={d.effectiveDate.toISOString()}>{formatDate(d.effectiveDate)}</time></td>
              <td><code>站点</code></td>
            </tr>
          )}
          {d.deadlineDate && (
            <tr>
              <td>截止日期</td>
              <td><time datetime={d.deadlineDate.toISOString()}>{formatDate(d.deadlineDate)}</time></td>
              <td><code class={deadlineUrgent ? 'ref-urgent' : ''}>{deadlineUrgent ? '紧迫' : '站点'}</code></td>
            </tr>
          )}
          <tr>
            <td>规则中心</td>
            <td><a href={withBase('/radar/')}>所有规则雷达</a></td>
            <td><code>站内</code></td>
          </tr>
          <tr>
            <td>清单中心</td>
            <td><a href={withBase('/checklists/')}>执行清单</a></td>
            <td><code>站内</code></td>
          </tr>
        </tbody>
      </table>
    </aside>
  </article>
</BaseLayout>

<script>
  // ==========================================================================
  // 复制 Markdown 摘要(沿用原逻辑)
  // ==========================================================================
  const btn = document.querySelector<HTMLButtonElement>('.copy-summary-btn');
  if (btn) {
    const label = btn.querySelector<HTMLSpanElement>('.copy-default') || btn;
    const ORIG = label.textContent || '📋 复制摘要';
    let resetTimer: number | null = null;

    const build = () => {
      const ds = btn.dataset;
      const title = ds.csTitle || '';
      const status = ds.csStatus || '';
      const risk = ds.csRisk || '';
      const eff = ds.csEffective || '';
      const slug = ds.csSlug || '';
      const summary = ds.csSummary || '';
      const url = `https://weiread.com/radar/${slug}/`;
      const effLine = eff ? `- 生效日期: ${eff}` : '- 生效日期: 持续关注';
      return [
        `### ${title}`,
        `- 状态: ${status}`,
        `- 风险等级: ${risk}`,
        effLine,
        `- 链接: ${url}`,
        '',
        '## 简要',
        summary,
      ].join('\n');
    };

    const setState = (text: string, state: 'ok' | 'err' | null) => {
      label.textContent = text;
      if (state) btn.setAttribute('data-state', state);
      else btn.removeAttribute('data-state');
      if (resetTimer) window.clearTimeout(resetTimer);
      resetTimer = window.setTimeout(() => {
        label.textContent = ORIG;
        btn.removeAttribute('data-state');
      }, 2000);
    };

    btn.addEventListener('click', async () => {
      const text = build();
      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(text);
          setState('✅ 已复制', 'ok');
          return;
        }
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.setAttribute('readonly', '');
        ta.style.position = 'fixed';
        ta.style.top = '0';
        ta.style.left = '0';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        const ok = document.execCommand('copy');
        document.body.removeChild(ta);
        if (ok) {
          setState('✅ 已复制', 'ok');
        } else {
          setState('❌ 请手动复制', 'err');
        }
      } catch {
        setState('❌ 请手动复制', 'err');
      }
    });
  }

  // ==========================================================================
  // 模式感知:H2 段在新手模式折叠(<details>),老手模式展开
  // --------------------------------------------------------------------------
  // 策略:
  //   1. SSR 渲染时 markdown 的所有 H2 都直接展开在 .prose 内
  //   2. client script 启动时 + 每次 body[data-mode] 变化时:
  //      - 如果当前是 beginner:把 foldKeys 对应的 H2 段(它和后续到下个 H2 之前
  //        的兄弟节点)wrap 进 <details><summary>...</summary>...</details>
  //      - 如果当前是 expert:把所有已 wrap 的 <details> 拆开,把 children 还原
  //        回 prose 容器
  //   3. 用 data-astro-cid 区分原 markdown 节点 vs 包装节点,避免重复 wrap
  //   4. mode 初始值从 body[data-mode] 读,与 BaseLayout 的 anti-FOUC 对齐
  // ==========================================================================
  const prose = document.querySelector<HTMLElement>('[data-prose-fold]');
  if (prose) {
    let foldKeys: string[] = [];
    try {
      foldKeys = JSON.parse(prose.dataset.foldKeys || '[]');
    } catch {
      foldKeys = [];
    }
    const foldSet = new Set(foldKeys);
    // 已经 wrap 的 H2 缓存(避免重复 wrap)
    const wrappedMap = new WeakMap<HTMLHeadingElement, { details: HTMLDetailsElement; parent: Node; siblings: Node[] }>();

    /** 把 h2 节点 + 它之后到下一个 H2 之前的兄弟节点 wrap 进 details */
    function wrapSection(h2: HTMLHeadingElement): void {
      if (wrappedMap.has(h2)) return;
      const parent = h2.parentNode;
      if (!parent || parent !== prose) return;
      const details = document.createElement('details');
      details.className = 'mode-fold-block';
      const summary = document.createElement('summary');
      summary.className = 'mode-fold-summary';
      // 在 H2 文本前加 emoji 装饰(用 getH2Text 剥掉可能已存在的 emoji span)
      const text = getH2Text(h2);
      const emoji = pickEmoji(text);
      summary.innerHTML =
        `<span class="mode-fold-emoji" aria-hidden="true">${emoji}</span>` +
        `<span class="mode-fold-title">${text}</span>` +
        `<span class="mode-fold-hint" aria-hidden="true">点击展开 / 收起</span>`;
      details.appendChild(summary);
      // 收集从 h2 之后到下一个 H2 之前的节点(包含 H2 自身一并搬入)
      const siblings: Node[] = [];
      let cur: ChildNode | null = h2;
      while (cur) {
        const next: ChildNode | null = cur.nextSibling;
        const isH2 = cur.nodeType === 1 && (cur as Element).tagName === 'H2';
        siblings.push(cur);
        if (next && next.nodeType === 1 && (next as Element).tagName === 'H2') {
          // 下一个兄弟是 H2,停止收集(不包括它)
          break;
        }
        if (!next) break;
        cur = next;
      }
      for (const node of siblings) {
        details.appendChild(node);
      }
      // 把 details 插到 h2 原本的位置
      parent.insertBefore(details, h2);
      // h2 已被搬走,缓存占位节点以便 unwrap
      wrappedMap.set(h2, { details, parent, siblings });
    }

    function unwrapAll(): void {
      // 找到所有 mode-fold-block 并还原
      const blocks = prose.querySelectorAll<HTMLDetailsElement>('.mode-fold-block');
      blocks.forEach((details) => {
        const parent = details.parentNode;
        if (!parent) return;
        // 把 details 里的所有子节点(从 summary 后开始)搬回 parent,
        // 然后 details 本身移除
        const frag = document.createDocumentFragment();
        // 跳过 summary,只搬内容
        Array.from(details.childNodes).forEach((n) => {
          if (n.nodeType === 1 && (n as Element).classList.contains('mode-fold-summary')) return;
          frag.appendChild(n);
        });
        parent.insertBefore(frag, details);
        parent.removeChild(details);
      });
    }

    /**
     * 根据 H2 文本匹配 emoji 前缀
     * - 匹配顺序敏感(更具体的关键词放前面)
     * - 新手模式 summary / 老手模式 H2 prefix 共用同一份映射
     */
    function pickEmoji(text: string): string {
      if (text.includes('一句话结论')) return '🎯';
      if (text.includes('这是啥')) return '📖';
      if (text.includes('为什么跟你有关')) return '🤝';
      if (text.includes('适用范围')) return '🎯';
      if (text.includes('关键时间线') || text.includes('关键时间')) return '⏰';
      if (text.includes('核心义务') || text.includes('核心变化')) return '⚙️';
      if (text.includes('你现在要做什么') || text.includes('你要做什么')) return '✅';
      if (text.includes('不处理') || text.includes('不做的')) return '⚠️';
      if (text.includes('常见误区')) return '💡';
      if (text.includes('常见问题')) return '❓';
      if (text.includes('风险提示')) return '⚠️';
      if (text.includes('合规清单')) return '☑️';
      if (text.includes('核对日期')) return '📅';
      if (text.includes('相关规则')) return '🔀';
      if (text.includes('相关清单')) return '📋';
      if (text.includes('官方') || text.includes('原始来源') || text.includes('来源')) return '🔗';
      if (text.includes('亚马逊')) return '🛒';
      return '📌';
    }

    /**
     * 取 H2 纯文本(剥掉可能存在的 emoji / 装饰节点)
     * - 用于 fold key 匹配,避免子节点文本污染
     */
    function getH2Text(h2: HTMLHeadingElement): string {
      return (h2.textContent || '').trim();
    }

    function applyMode(mode: string): void {
      // 1) 总是先 unwrap 旧的 details wrap(防 SSR 切换中残留)
      unwrapAll();
      // 2) 新手模式额外 wrap fold 段(emoji 前缀由 SSR <style is:inline> ::before 注入)
      if (mode === 'beginner') {
        const h2s = prose.querySelectorAll<HTMLHeadingElement>('h2');
        h2s.forEach((h2) => {
          const t = getH2Text(h2);
          if (foldSet.has(t)) wrapSection(h2);
        });
      }
    }

    // 初次应用
    const initMode = document.body.getAttribute('data-mode') || 'expert';
    applyMode(initMode);

    // 监听 body[data-mode] 变化(用户点 ModeToggle 切换)
    const obs = new MutationObserver(() => {
      const m = document.body.getAttribute('data-mode') || 'expert';
      applyMode(m);
    });
    obs.observe(document.body, { attributes: true, attributeFilter: ['data-mode'] });
  }
</script>

<style>
  /* ======================================================================
     详情页 · 新手/老手 模式视觉差异
