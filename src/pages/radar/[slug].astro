  /* ---------- 详情页右上角内容状态徽标 ---------- */
  .kind {
    display: inline-flex;
    align-items: center;
    padding: 0.2em 0.65em;
    font-size: 0.78rem;
    font-weight: 500;
    border-radius: var(--radius-sm);
    border: 1px solid;
