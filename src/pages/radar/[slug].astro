  }
  .kind-basic { background: var(--color-ink-50); color: var(--color-ink-700); border-color: var(--color-ink-200); }
  .kind-update { background: var(--color-accent-50); color: var(--color-accent-700); border-color: var(--color-accent-100); }
  .kind-example { background: var(--color-warn-bg); color: var(--color-warn-text); border-color: var(--color-warn-border); }
  .kind-pending { background: #f5f3ff; color: #6d28d9; border-color: #ddd6fe; }

  /* ---------- 倒计时徽标(SSR 算好) ---------- */
  .deadline-badge {
    display: inline-flex;
    align-items: center;
    vertical-align: middle;
    margin-left: 0.5em;
    padding: 0.2em 0.7em;
