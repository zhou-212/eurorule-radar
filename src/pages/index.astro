---
import BaseLayout from '../layouts/BaseLayout.astro';
import RadarCard from '../components/RadarCard.astro';
import ChecklistCard from '../components/ChecklistCard.astro';
import CalendarEvent from '../components/CalendarEvent.astro';
import SubscribeForm from '../components/SubscribeForm.astro';
import { getCollection } from 'astro:content';
import calendarData from '../content/calendar/events.json';
import { SITE_DEFAULTS, getRiskClass } from '../lib/radar';
import { daysFromNow, formatDate } from '../lib/date';
import { withBase, siteAsDir } from '../lib/url';
import { getRadarRules, getContentKindKey } from '../lib/radar-source';

// 数据源切换:getCollection('radar') → getRadarRules()
// getRadarRules 内部:API 成功用 API 数据;任何 error → fallback 到静态 content 集合。
// 顶层 try/catch 兜底 —— 万一 fallback 自身抛错(理论上不会),也降级到空数组,
let radars: Awaited<ReturnType<typeof getRadarRules>> = [];
try {
  radars = await getRadarRules();
} catch (err) {
  // eslint-disable-next-line no-console
  console.error('[index.astro] getRadarRules failed, rendering empty:', (err as Error).message);
  radars = [];
}

// 内容时效原则:
//   - "近期更新":必须有官方原始来源 + 核对日期 + 具体更新,缺一不可。
//   - 当前所有规则都是 2026-01 核对的"基础规则",不属于"近期更新"。
//   - 因此首页只展示"基础规则",绝不为了凑数把基础规则贴"近期更新"标签。
// 派生逻辑用 `getContentKindKey(r) === 'update'` 风格(英文键,对应后端 API
// contentKind 字段);`data.contentKind` 仍是中文展示值(给 RadarCard.astro
// 渲染徽标,锁定文件不能改)。
const recentUpdates = radars.filter((r) => getContentKindKey(r) === 'update');
// 顶部紧凑区块:最多 3 张"近期更新"卡片,带"距 effectiveDate 的天数"
// 没有时不渲染整个 section(留出空状态说明给下方"近期更新(已核对)"区块)
const recentUpdatesTop3 = recentUpdates.slice(0, 3);
const basicRules = radars.filter((r) => getContentKindKey(r) === 'basic');
const basicFeatured = basicRules.filter((r) => r.data.featured).slice(0, 3);
const basicOthers = basicRules.filter((r) => !r.data.featured).slice(0, 3);

const checklists = (await getCollection('checklists'))
  .sort((a, b) => +b.data.verifiedDate - +a.data.verifiedDate)
  .slice(0, 3);

// 日历:默认只看真实 (非示例) 且未过期 的事件
const upcomingAll = calendarData
  .filter((e) => daysFromNow(e.date) >= 0)
  .sort((a, b) => +new Date(a.date) - +new Date(b.date));
const realUpcoming = upcomingAll.filter((e) => !e.isExample).slice(0, 4);

// 绝对 URL helper (用于 JSON-LD):SITE 已包含 project path(Astro 自动)
const siteStr = siteAsDir(Astro.site);

// 首页搜索:/search.json 端点的 BASE-aware 路径(由另一个 agent 提供端点,
// 这里只消费 URL 字符串,不耦合实现)。空字符串表示 BASE 解析失败(降级到相对路径)。
const searchJsonUrl = withBase('/search.json');
// 详情页 BASE-aware 路径前缀(用于客户端构造 /radar/<slug>/)
const radarBaseHref = withBase('/radar/');

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      name: SITE_DEFAULTS.name,
      alternateName: SITE_DEFAULTS.enName,
      url: siteStr || undefined,
      description: SITE_DEFAULTS.description,
      inLanguage: 'zh-CN',
      potentialAction: {
        '@type': 'SearchAction',
        target: siteStr ? `${siteStr}radar?q={search_term_string}` : undefined,
        'query-input': 'required name=search_term_string',
      },
    },
    {
      '@type': 'Organization',
      name: SITE_DEFAULTS.name,
      url: siteStr || undefined,
      logo: siteStr ? `${siteStr}favicon.svg` : undefined,
    },
  ],
};
---

<BaseLayout
  title="欧规雷达 · 亚马逊欧洲站规则变化追踪与执行清单"
  description={SITE_DEFAULTS.description}
  jsonLd={jsonLd}
>
  <!-- ============================================
       老手模式 Hero(默认/现状)
       - 标题强调"公告变清单",适合已有经验的老卖家
       - 含搜索框(下拉浮在 hero 之外)
       ============================================ -->
  <section class="section hero" data-show-on="expert" aria-labelledby="hero-expert-title">
    <div class="container">
      <p class="hero-eyebrow">面向中国亚马逊欧洲站中小卖家</p>
      <h1 id="hero-expert-title" class="hero-title">欧洲站规则更新太快?把公告变成你今天能完成的行动清单。</h1>
      <p class="hero-sub">追踪亚马逊欧洲站、欧盟法规、成员国官方公告 → 判断是否影响你的店铺、类目和库存 → 输出今天能做的行动 + 截止日期。</p>
      <div class="hero-cta">
        <a href={withBase('/radar/')} class="btn btn-primary">免费查看本周规则</a>
        <a href={withBase('/self-check/')} class="btn btn-secondary">3 题判断你需要关注什么</a>
      </div>
      <ul class="hero-points">
        <li>✓ 中文整理,无术语堆砌</li>
        <li>✓ 每条规则附原始来源与核对日期</li>
        <li>✓ 明确区分"已生效"vs"示例内容"</li>
        <li>✓ 行动清单可勾选、可打印</li>
      </ul>

      <!-- 首页搜索(消费 /search.json 端点,客户端过滤) — 仅老手模式 -->
      <div
        class="radar-search"
        data-radar-search-root
        data-search-url={searchJsonUrl}
        data-radar-base={radarBaseHref}
      >
        <label for="radar-search-input" class="sr-only">搜索规则</label>
        <div class="radar-search-input-wrap">
          <svg
            class="radar-search-icon"
            viewBox="0 0 24 24"
            width="20"
            height="20"
            aria-hidden="true"
            focusable="false"
          >
            <circle cx="11" cy="11" r="7" fill="none" stroke="currentColor" stroke-width="2" />
            <line x1="16.5" y1="16.5" x2="21" y2="21" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
          <input
            type="search"
            id="radar-search-input"
            class="input radar-search-input"
            placeholder="搜索法规、产品名、关键词…"
            autocomplete="off"
            autocorrect="off"
            autocapitalize="off"
            spellcheck="false"
            inputmode="search"
            enterkeyhint="search"
            aria-autocomplete="list"
            aria-expanded="false"
            aria-controls="radar-search-results"
            aria-activedescendant=""
          />
        </div>
        <div
          id="radar-search-results"
          class="radar-search-results"
          role="listbox"
          aria-label="搜索结果"
          hidden
        ></div>
        <p class="radar-search-help sr-only" id="radar-search-help">
          输入时显示前 5 条匹配规则;按上下键切换,Enter 打开,Esc 关闭。
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================
       新手模式 Hero(完全不同的视觉与文案)
       - 浅黄→浅绿渐变底,品牌色 token 已自动切换
       - 2 个大 CTA:测一下 / 看 5 步走
       ============================================ -->
  <section class="section hero-beginner" data-show-on="beginner" aria-labelledby="hero-beginner-title">
    <div class="container">
      <p class="hero-beginner-eyebrow">🌱 新手起步 · 第一次卖欧洲站</p>
      <h1 id="hero-beginner-title" class="hero-beginner-title">我是新手, 怎么开始卖欧洲站?</h1>
      <p class="hero-beginner-sub">3 步测你适不适合, 5 篇文章带你上路, 8 个名词先搞懂 —— 别急着啃法规, 先把节奏走顺。</p>
      <div class="hero-beginner-cta">
        <a href={withBase('/self-check/')} class="btn btn-beginner-primary">🌱 我是新手, 测一下</a>
        <a href={withBase('/radar/guide-seller-90days/')} class="btn btn-beginner-secondary">📚 看新手起步 5 步走</a>
      </div>
      <ul class="hero-beginner-points">
        <li>✓ 30 分钟起步, 不需要先懂法规</li>
        <li>✓ 全程中文 + 大白话, 没用过也看得懂</li>
        <li>✓ 每步都给"今天能做什么"的具体动作</li>
        <li>✓ 走完能直接进欧洲站后台操作</li>
      </ul>
    </div>
  </section>

  <!-- ============================================
       老手模式专属:近期更新(紧凑卡片,最多 3 张)
       新手模式:不展示,改推下面的"新手起步 5 步走"
       ============================================ -->
  {recentUpdatesTop3.length > 0 && (
    <section class="section section-tight section-bg" id="recent-top" aria-labelledby="recent-top-title" data-show-on="expert">
      <div class="container">
        <div class="section-head">
          <h2 id="recent-top-title">🆕 近期更新</h2>
          <a href={withBase('/radar/')} class="section-head-link">查看全部 →</a>
        </div>
        <div class="grid grid-3">
          {recentUpdatesTop3.map((r) => {
            const slug = r.id.replace(/\.(md|mdx)$/, '');
            const href = withBase(`/radar/${slug}/`);
            const eff = r.data.effectiveDate;
            const days = eff ? daysFromNow(eff) : null;
            const dayText =
              days === null
                ? '持续关注'
                : days > 0
                  ? `还有 ${days} 天`
                  : days === 0
                    ? '今天生效'
                    : `已生效 ${-days} 天`;
            return (
              <a href={href} class="card card-hover recent-mini">
                <div class="recent-mini-top">
                  <span class={`risk ${getRiskClass(r.data.riskLevel)}`}>风险:{r.data.riskLevel}</span>
                  <span class={`recent-mini-days ${days !== null && days <= 14 && days >= 0 ? 'is-urgent' : days !== null && days < 0 ? 'is-past' : ''}`}>{dayText}</span>
                </div>
                <h3 class="recent-mini-title">{r.data.title}</h3>
                {eff && (
                  <p class="recent-mini-eff">
                    生效日期:<time datetime={eff.toISOString()}>{formatDate(eff)}</time>
                  </p>
                )}
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ============================================
       新手模式专属:🌱 新手起步 5 步走
       5 张卡片,每张是一个 guide-* 详情页
       每张有数字徽标 + 标题 + 一句话简介 + 阅读时长
       ============================================ -->
  <section class="section section-tight" data-show-on="beginner" aria-labelledby="beginner-5steps-title">
    <div class="container">
      <div class="beginner-block beginner-5steps">
        <div class="beginner-block-header">
          <span class="beginner-block-icon" aria-hidden="true">🌱</span>
          <h2 class="beginner-block-title" id="beginner-5steps-title">新手起步 5 步走</h2>
        </div>
        <p class="beginner-block-sub">按顺序读,每周 1-2 篇,大约 3-4 周走完。第一步就决定要不要开始, 不要一口气啃完。</p>
        <div class="beginner-5steps-grid">
          <a href={withBase('/radar/guide-seller-90days/')} class="guide-step">
            <span class="guide-step-num" aria-hidden="true">1</span>
            <span class="guide-step-body">
              <span class="guide-step-title">新卖家 90 天路线图</span>
              <span class="guide-step-desc">从 0 走到"基本能开卖",每周 1-2 件事,告诉你每一步在后台哪个页面点哪个按钮。</span>
              <span class="guide-step-time">⏱ 约 8 分钟阅读 · 第 1 周</span>
            </span>
          </a>
          <a href={withBase('/radar/guide-8-terms/')} class="guide-step">
            <span class="guide-step-num" aria-hidden="true">2</span>
            <span class="guide-step-body">
              <span class="guide-step-title">8 大合规名词一次搞懂</span>
              <span class="guide-step-desc">GPSR / CE / EPR / VAT / EPREL / IOSS / PPWR / EUDR, 8 个最常听到的缩写, 大白话讲清楚。</span>
              <span class="guide-step-time">⏱ 约 3 分钟阅读 · 第 1 周</span>
            </span>
          </a>
          <a href={withBase('/radar/guide-amazon-gpsr-email/')} class="guide-step">
            <span class="guide-step-num" aria-hidden="true">3</span>
            <span class="guide-step-body">
              <span class="guide-step-title">Amazon GPSR 责任人邮箱怎么填</span>
              <span class="guide-step-desc">GPSR 是 2024 年底生效的硬性要求, 没填就会被下架。这一步是开卖前必做。</span>
              <span class="guide-step-time">⏱ 约 5 分钟阅读 · 第 2 周</span>
            </span>
          </a>
          <a href={withBase('/radar/guide-pick-first-country/')} class="guide-step">
            <span class="guide-step-num" aria-hidden="true">4</span>
            <span class="guide-step-body">
              <span class="guide-step-title">新手选第一个欧洲站卖哪个国家</span>
              <span class="guide-step-desc">德国 / 法国 / 意大利 / 西班牙各有门槛, 给新手的建议是"先一个站打透"。</span>
              <span class="guide-step-time">⏱ 约 4 分钟阅读 · 第 2 周</span>
            </span>
          </a>
          <a href={withBase('/radar/guide-ce-marking/')} class="guide-step">
            <span class="guide-step-num" aria-hidden="true">5</span>
            <span class="guide-step-body">
              <span class="guide-step-title">CE 标志到底要不要贴?怎么贴?</span>
              <span class="guide-step-desc">不是所有商品都需要 CE, 但需要时贴错位置会被海关扣。一张图讲清楚。</span>
              <span class="guide-step-time">⏱ 约 6 分钟阅读 · 第 3 周</span>
            </span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       老手模式专属:近期更新(已核对) / 基础规则
       新手模式:不展示(信息量过大,新手会劝退)
       ============================================ -->
  <section class="section section-tight" id="latest" data-show-on="expert" aria-labelledby="latest-title">
    <div class="container">
      <div class="section-head">
        <h2 id="latest-title">近期更新(已核对)</h2>
        <a href={withBase('/radar/')} class="section-head-link">查看全部 →</a>
      </div>
      {recentUpdates.length === 0 ? (
        <div class="empty-card">
          <p>暂未发布已核对的近期更新(2026 年新公告 / 修订 / 执法动态)。</p>
          <p class="empty-meta">
            近期更新需要 1) 找到官方原始来源(官方公告 / EUR-Lex 法规原文 / 成员国主管机构),2) 人工核对发布日期、生效日期、适用范围,
            3) 写"你现在要做什么"清单。
            不允许把未核实的社群消息、AI 推断包装成"新近更新"。运营正在分批核实;
            请<strong>定期回访本站</strong>或关注 GitHub 仓库的更新。
          </p>
        </div>
      ) : (
        <div class="grid grid-3">
          {recentUpdates.map((r) => <RadarCard entry={r} />)}
        </div>
      )}

      <div class="section-head section-head-divider">
        <h2>已核对的基础规则</h2>
        <span class="section-head-meta">长期有效的常驻要求,不是"新近变化"</span>
      </div>
      <div class="grid grid-3">
        {basicFeatured.map((r) => <RadarCard entry={r} />)}
        {basicOthers.map((r) => <RadarCard entry={r} />)}
      </div>
      <p class="section-foot">
        <a href={withBase('/radar/')}>查看全部 {basicRules.length} 条基础规则 →</a>
      </p>
    </div>
  </section>

  <!-- ============================================
       新手模式专属:📖 8 大名词先搞懂(大区块)
       直接链到 /radar/guide-8-terms/ —— "我先记 8 个缩写再继续"
       ============================================ -->
  <section class="section section-tight" data-show-on="beginner" aria-labelledby="beginner-terms-title">
    <div class="container">
      <div class="beginner-block beginner-terms">
        <div class="beginner-block-header">
          <span class="beginner-block-icon" aria-hidden="true">📖</span>
          <h2 class="beginner-block-title" id="beginner-terms-title">8 大名词先搞懂</h2>
        </div>
        <p class="beginner-block-sub">走进欧洲站后台前, 先认熟 8 个最常听到的缩写 —— 不然开账号 / 看公告 / 找客服都像听天书。</p>
        <div class="terms-cta">
          <div class="terms-cta-body">
            <p class="terms-cta-title">3 分钟扫盲, 不留知识盲点</p>
            <p class="terms-cta-desc">GPSR / CE / EPR / VAT / EPREL / IOSS / PPWR / EUDR —— 一张卡讲清楚"是谁关心, 什么时候要管"。</p>
            <ul class="terms-cta-tags" aria-label="本卡涵盖的名词">
              <li class="terms-cta-tag">GPSR</li>
              <li class="terms-cta-tag">CE</li>
              <li class="terms-cta-tag">EPR</li>
              <li class="terms-cta-tag">VAT</li>
              <li class="terms-cta-tag">EPREL</li>
              <li class="terms-cta-tag">IOSS</li>
              <li class="terms-cta-tag">PPWR</li>
              <li class="terms-cta-tag">EUDR</li>
            </ul>
          </div>
          <a href={withBase('/radar/guide-8-terms/')} class="terms-cta-btn">
            🚀 现在去记 8 个名词
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       老手模式专属:截止日历(预览) + 核心价值 + 行动清单 + 自测 + 订阅
       全部仅老手模式可见
       ============================================ -->
  <section class="section section-tight section-bg" data-show-on="expert" aria-labelledby="calendar-title">
    <div class="container">
      <div class="section-head">
        <h2 id="calendar-title">未来 90 天重点节点</h2>
        <a href={withBase('/calendar/')} class="section-head-link">完整日历 →</a>
      </div>
      {realUpcoming.length === 0 ? (
        <div class="empty-card">
          <p>未来 90 天内暂无已核实的真实截止日。日历只展示有官方原始来源的节点;未核实的日期不会上线,以避免误导。</p>
          <p class="empty-meta">查看 <a href={withBase('/calendar/')}>完整日历</a> 或<strong>定期回访本站</strong>。</p>
        </div>
      ) : (
        <div class="grid grid-2">
          {realUpcoming.map((e) => <CalendarEvent event={e} />)}
        </div>
      )}
    </div>
  </section>

  <section class="section" data-show-on="expert" aria-labelledby="value-title">
    <div class="container">
      <h2 id="value-title" class="value-title">我们解决什么</h2>
      <div class="grid grid-3">
        <div class="card value-card">
          <h3>追踪变化</h3>
          <p>从 Amazon Seller Central、EUR-Lex、欧盟成员国机构等权威源持续监控,过滤噪音,只保留与你有关的规则变化。</p>
        </div>
        <div class="card value-card">
          <h3>判断影响</h3>
          <p>每个规则卡片标出适用范围(站点、卖家类型、类目)、风险等级(高/中/低)与生效状态(已生效/即将生效/持续关注)。</p>
        </div>
        <div class="card value-card">
          <h3>给出行动</h3>
          <p>每条规则都附带 3-6 项可立即执行的行动项;遇到合规通知有 48 小时应对清单;每条都附原始来源链接供你二次核实。</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-bg" data-show-on="expert" aria-labelledby="checklists-title">
    <div class="container">
      <div class="section-head">
        <h2 id="checklists-title">常用行动清单</h2>
        <a href={withBase('/checklists/')} class="section-head-link">查看全部 →</a>
      </div>
      <div class="grid grid-3">
        {checklists.map((c) => <ChecklistCard entry={c} />)}
      </div>
    </div>
  </section>

  <section class="section" data-show-on="expert" aria-labelledby="selfcheck-promo-title">
    <div class="container">
      <div class="grid grid-2 self-check-promo">
        <div>
          <h2 id="selfcheck-promo-title">不确定你该先看哪条规则?</h2>
          <p>3-5 题,基于你的销售国家、商品类目、合规经验,给出"优先关注主题"和"推荐阅读清单"。</p>
          <p>结果只作导航建议,<strong>不构成法律或合规结论</strong>。</p>
          <a href={withBase('/self-check/')} class="btn btn-primary">开始自测</a>
