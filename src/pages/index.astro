<script>
  /**
   * 首页搜索(消费 /search.json 端点):
   *  - 输入 debounce 200ms
   *  - 客户端按 title + summary + tags 过滤
   *  - 显示前 5 条结果,关键词 <mark> 高亮
   *  - 键盘 ↑↓ 导航,Enter 跳转,Esc 关闭
   *  - 移动端 inputmode="search" / enterkeyhint="search"
   *  - 数据由 SSR 注入的 data-search-url / data-radar-base 决定(BASE-aware)
   */
  type SearchItem = {
    slug: string;
    title: string;
    summary: string;
    tags?: string[];
    riskLevel?: '高' | '中' | '低' | string;
  };

  const root = document.querySelector<HTMLElement>('[data-radar-search-root]');
  if (root) {
    const input = root.querySelector<HTMLInputElement>('#radar-search-input');
    const list = root.querySelector<HTMLElement>('#radar-search-results');
    const searchUrl = root.dataset.searchUrl || '/search.json';
    const radarBase = root.dataset.radarBase || '/radar/';

    if (input && list) {
      let dataPromise: Promise<SearchItem[]> | null = null;
      let currentMatches: SearchItem[] = [];
      let currentQuery = '';
      let activeIndex = -1;
      let blurTimer: number | null = null;

      // ---------- 工具函数 ----------
      const escapeHtml = (s: string): string =>
        s.replace(/[&<>"']/g, (ch) =>
          ch === '&' ? '&amp;' :
          ch === '<' ? '&lt;' :
          ch === '>' ? '&gt;' :
          ch === '"' ? '&quot;' : '&#39;'
        );

      const escapeRegex = (s: string): string =>
        s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');

      const highlight = (text: string, q: string): string => {
        if (!q) return escapeHtml(text);
        const safe = escapeHtml(text);
        const re = new RegExp(escapeRegex(escapeHtml(q)), 'gi');
        return safe.replace(re, (m) => `<mark>${m}</mark>`);
      };

      const debounce = <F extends (...a: any[]) => void>(fn: F, ms: number) => {
        let t: number | null = null;
        return (...args: Parameters<F>) => {
          if (t !== null) window.clearTimeout(t);
          t = window.setTimeout(() => fn(...args), ms);
        };
      };

      // 风险等级 → 已有的 .risk 修饰类
      const riskClass = (level: string | undefined): string => {
        if (level === '高') return 'risk-high';
        if (level === '中') return 'risk-medium';
        if (level === '低') return 'risk-low';
        return 'risk-low';
      };

      // ---------- 数据加载 ----------
      const ensureData = (): Promise<SearchItem[]> => {
        if (dataPromise) return dataPromise;
        dataPromise = fetch(searchUrl, { credentials: 'same-origin' })
          .then((r) => {
            if (!r.ok) throw new Error(`search.json HTTP ${r.status}`);
            return r.json() as Promise<SearchItem[] | { items?: SearchItem[] }>;
          })
          .then((raw) => {
            // 兼容两种返回:裸数组 / {items: [...]}
            if (Array.isArray(raw)) return raw;
            if (raw && Array.isArray((raw as any).items)) return (raw as any).items;
            return [];
          })
          .catch((err) => {
            // eslint-disable-next-line no-console
            console.warn('[radar-search] /search.json 加载失败,搜索功能降级:', err);
            return [];
          });
        return dataPromise;
      };

      // ---------- 渲染 ----------
      const renderEmpty = () => {
        list!.innerHTML = '<div class="radar-search-empty">无匹配,试试其他关键词</div>';
        list!.hidden = false;
        input.setAttribute('aria-expanded', 'true');
        activeIndex = -1;
        input.setAttribute('aria-activedescendant', '');
      };

      const renderMatches = (matches: SearchItem[], q: string) => {
        if (matches.length === 0) {
          renderEmpty();
          return;
        }
        const html = matches
          .map((m, i) => {
            const href = radarBase + encodeURIComponent(m.slug) + '/';
            const risk = escapeHtml(m.riskLevel || '');
            return (
              `<a href="${href}" class="radar-search-result" role="option" data-idx="${i}" id="radar-search-result-${i}">` +
                `<div class="radar-search-result-top">` +
                  `<span class="risk ${riskClass(m.riskLevel)}">风险:${risk}</span>` +
                `</div>` +
                `<p class="radar-search-result-title">${highlight(m.title, q)}</p>` +
                `<p class="radar-search-result-summary">${highlight(m.summary, q)}</p>` +
              `</a>`
            );
          })
          .join('');
        list!.innerHTML = html;
        list!.hidden = false;
        input.setAttribute('aria-expanded', 'true');
      };

      const renderLoading = () => {
        list!.innerHTML = '<div class="radar-search-loading">正在加载索引…</div>';
        list!.hidden = false;
        input.setAttribute('aria-expanded', 'true');
      };

      const close = () => {
        list!.hidden = true;
        input.setAttribute('aria-expanded', 'false');
        input.setAttribute('aria-activedescendant', '');
        activeIndex = -1;
      };

      // ---------- 搜索执行 ----------
      const runSearch = async (rawQ: string) => {
        const q = rawQ.trim();
        currentQuery = q;
        if (!q) {
          close();
          return;
        }
        // 第一次输入时展示 loading,等待 /search.json
        if (!dataPromise) renderLoading();
        const data = await ensureData();
        if (currentQuery !== q) return; // 已被新输入覆盖
        const lower = q.toLowerCase();
        const matches: SearchItem[] = [];
        for (const item of data) {
          if (!item || typeof item !== 'object') continue;
          const tags = Array.isArray(item.tags) ? item.tags.join(' ') : '';
          const hay = `${item.title || ''} ${item.summary || ''} ${tags}`.toLowerCase();
          if (hay.includes(lower)) {
            matches.push(item);
            if (matches.length >= 5) break;
          }
        }
        currentMatches = matches;
        activeIndex = -1;
        renderMatches(matches, q);
      };

      const debouncedSearch = debounce((q: string) => {
        runSearch(q).catch((err) => {
          // eslint-disable-next-line no-console
          console.warn('[radar-search] runSearch 异常:', err);
          if (list) {
            list.innerHTML = '<div class="radar-search-error">搜索出错,请稍后重试</div>';
            list.hidden = false;
          }
        });
      }, 200);

      const updateActive = () => {
        const items = list!.querySelectorAll<HTMLElement>('.radar-search-result');
        items.forEach((el, i) => {
          const isActive = i === activeIndex;
          el.classList.toggle('is-active', isActive);
          if (isActive) {
            el.scrollIntoView({ block: 'nearest' });
            input.setAttribute('aria-activedescendant', el.id);
          }
        });
        if (activeIndex < 0) input.setAttribute('aria-activedescendant', '');
      };

      // ---------- 事件绑定 ----------
      input.addEventListener('input', () => debouncedSearch(input.value));

      input.addEventListener('focus', () => {
        if (blurTimer !== null) {
          window.clearTimeout(blurTimer);
          blurTimer = null;
        }
        // 有未关闭的旧结果时保留;有当前 query 时再跑一次(确保数据就绪后展示)
        if (input.value.trim()) {
          if (currentMatches.length > 0 && !list.hidden) return;
          runSearch(input.value);
        }
      });

      input.addEventListener('blur', () => {
        // 延迟关闭,允许 click 结果跳转
        if (blurTimer !== null) window.clearTimeout(blurTimer);
        blurTimer = window.setTimeout(() => {
          close();
        }, 150);
      });

      input.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          if (list.hidden) {
            if (input.value.trim()) runSearch(input.value);
            return;
          }
          if (currentMatches.length === 0) return;
          activeIndex = (activeIndex + 1) % currentMatches.length;
          updateActive();
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          if (list.hidden || currentMatches.length === 0) return;
          activeIndex = activeIndex <= 0 ? currentMatches.length - 1 : activeIndex - 1;
          updateActive();
        } else if (e.key === 'Enter') {
          if (activeIndex >= 0 && currentMatches[activeIndex]) {
            e.preventDefault();
            const m = currentMatches[activeIndex];
            window.location.href = radarBase + encodeURIComponent(m.slug) + '/';
          } else if (currentMatches.length > 0) {
            // 没高亮时按 Enter 默认跳第一条
            e.preventDefault();
            const m = currentMatches[0];
            window.location.href = radarBase + encodeURIComponent(m.slug) + '/';
          }
          // 无结果时不拦截(让表单默认行为兜底;当前是 input,无副作用)
        } else if (e.key === 'Escape') {
          if (!list.hidden) {
            e.preventDefault();
            close();
          }
        }
      });

      // 点击下拉内空白处不关闭(链接 click 自然跳转)
      list.addEventListener('mousedown', (e) => {
        // 阻止 input 的 blur 触发关闭
        e.preventDefault();
      });

      // 点击页面其它区域关闭
      document.addEventListener('click', (e) => {
        const t = e.target as Node;
        if (!root.contains(t)) close();
      });
    }
  }
</script>
