# ============================================================
# 欧规雷达 · EuroRule Radar — 环境变量示例
# ============================================================
# 复制本文件为 .env,然后填入真实值。
# 即使不配置任何环境变量,项目也可运行 —— 用占位默认值(部分功能降级)。
#
# 使用方法:
#   cp .env.example .env        # macOS / Linux
#   Copy-Item .env.example .env # PowerShell
#   # 然后编辑 .env
#
# Astro 加载环境变量: process.env.SITE / process.env.BASE
#
# ⚠️ 不要把真实密钥写进 .env.example(只放占位 / 注释)。
# ⚠️ .env.example 是公开仓库文件,.env 是本地忽略文件(已在 .gitignore)。
# ============================================================

# ---- ⚠️ SITE 是上线前必配项 ----
# 部署到自定义域名 (https://eurorule.example.com):
#   SITE=https://eurorule.example.com
#   BASE=/            (留空也走默认 /)
#
# 部署到 GitHub Pages 项目页 (https://<user>.github.io/eurorule-radar/):
#   - 不需要设任何 env 变量 —— 工作流会自动用
#     SITE=https://<owner>.github.io/eurorule-radar
#     BASE=/eurorule-radar/
#   - 想要本地构建时也有正确 URL,设成相同值即可:
#     SITE=https://YOUR_GITHUB_USER.github.io/eurorule-radar
#     BASE=/eurorule-radar/
#
# ⚠️ 不设 SITE 的后果:
#   - robots.txt 不会输出 Sitemap 行(避免向搜索引擎提交一个假地址)
#   - 全部页面 <meta name="robots" content="noindex"> 防止被索引
#   - RSS feed 仍然生成但 link host 是占位
# 占位默认值 —— 本地随便跑跑可上线;Sitemap / canonical / OG / RSS 都会指向占位域,
# 搜索引擎会忽略,生产部署前必须替换。
SITE=https://YOUR_DOMAIN.com

# ---- BASE:站点子路径前缀 ----
# 默认 '/' (自定义域名根路径)
# GitHub Pages 项目页部署时建议 '/eurorule-radar/' (工作流默认就是这个)
# 工作流优先级:vars.BASE > 根据 SITE 是否存在推断 > 这里的默认值
# BASE=/

# ---- 联系邮箱(About / 隐私 / 订阅相关) ----
# 显示在 /about 与 /privacy 联系区域
CONTACT_EMAIL=YOUR_CONTACT_EMAIL@example.com

# ---- GitHub 仓库(About 页 "提交线索" 入口) ----
# 形如: https://github.com/<user>/eurorule-radar
GITHUB_REPO=https://github.com/YOUR_GITHUB_USER/eurorule-radar

# ---- 邮件订阅后端(可选) ----
# 默认 SubscribeForm 是禁用状态,不会发送任何数据。
# 启用步骤:
#   1) 部署自建后端,实现 POST /api/v1/subscriptions
#      请求体: { email, topics: string[], consent: boolean }
#   2) 复制 public/runtime-config.example.js 为 public/runtime-config.js
#   3) 在 runtime-config.js 填入:
#        window.__EURORULE_RUNTIME_CONFIG__ = { API_BASE_URL: 'https://api.example.com' }
#   4) 部署后访问页面,表单自动启用;失败会显示明确错误,不会假装成功。
#
# (旧)Tally / Brevo / ConvertKit 接入方式已废弃,见 README §7
# (老注释保留,提醒不要走 Tally 这类第三方 —— 隐私边界不清晰)

# ---- 分析(可选) ----
# 默认不内置分析;如需启用,把代码片段加到 src/layouts/BaseLayout.astro
# PLAUSIBLE_DOMAIN=eurorule.example.com

# ---- 后端 API(规则雷达数据源) ----
# 规则卡片首页 / 雷达页从后端 API 拉数据(取代纯静态 content 集合)。
# API 不可用时自动 fallback 到 src/content/radar/*.md。
# 后端契约:
#   GET  /api/v1/rules?contentKind=basic,update&page=1&pageSize=20
#   GET  /api/v1/rules/:slug
#   响应: { data: ApiRule[], pagination: { page, pageSize, total, totalPages } }
# ApiRule.contentKind 字段值域: 'basic' | 'update' | 'example' | 'pending'
PUBLIC_API_BASE=http://127.0.0.1:8788
